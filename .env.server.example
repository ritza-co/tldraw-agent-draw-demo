# Server-side environment for the Node backend (server/server.ts).
# Copy to `.env.server` and fill in. This file is read by the systemd unit
# (EnvironmentFile=) in production, or `node --env-file=.env.server` locally.
#
# These are SECRET provider keys and must never reach the client bundle (unlike
# VITE_TLDRAW_LICENSE_KEY in .env, which is intentionally public).
#
# Bring-your-own-key: these are all OPTIONAL. The app lets each visitor paste
# their own keys in the UI (stored only in their browser, sent as request
# headers). A key set here is just a server-side fallback used when a request
# carries no header — leave them blank for a public, shared-cost-free demo.
#
# If you do set fallbacks: the default model is claude-sonnet-4-5, so
# ANTHROPIC_API_KEY covers the agent; MISTRAL_API_KEY covers voice transcription.

ANTHROPIC_API_KEY=
MISTRAL_API_KEY=

# Optional — only needed if you select a model from these providers in the UI.
OPENAI_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# Port the Node server listens on (Caddy reverse-proxies to this).
PORT=3003
