# Server-side environment for the Node backend (server/server.ts).
# Copy to `.env.server` and fill in. This file is read by the systemd unit
# (EnvironmentFile=) in production, or `node --env-file=.env.server` locally.
#
# These are SECRET provider keys and must never reach the client bundle (unlike
# VITE_TLDRAW_LICENSE_KEY in .env, which is intentionally public).
#
# Only the keys for models you actually use need to be set. The default model is
# claude-sonnet-4-5, so ANTHROPIC_API_KEY is the minimum to make the agent work.
# MISTRAL_API_KEY is required for the voice-to-canvas transcription feature.

ANTHROPIC_API_KEY=
MISTRAL_API_KEY=

# Optional — only needed if you select a model from these providers in the UI.
OPENAI_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# Port the Node server listens on (Caddy reverse-proxies to this).
PORT=3003
